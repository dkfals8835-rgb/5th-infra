# GET 요청
curl https://api.github.com                             # 기본 GET
curl -s https://api.github.com | head -20               # 조용히 받아서 앞 20줄
curl -I https://google.com                              # 헤더만 확인
curl -L https://google.com -o /dev/null -w "%{http_code}\n"  # 상태 코드만 확인

# POST 요청
curl -X POST https://api.example.com/users \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer TOKEN" \
  -d '{"name":"ubuntu","email":"test@example.com"}'

# 파일로 바디 전달
curl -X POST https://api.example.com/data \
  -H "Content-Type: application/json" \
  -d @request.json

